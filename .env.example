# Template only — real values go in .env.local (gitignored) locally, and in
# Vercel → Project Settings → Environment Variables for deployed environments.
# Never commit real values to this file.

# Supabase (mobile project: lzhrntjwnmrpwebmqyha)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Absolute URL of the running admin panel. Used to build invite links in emails,
# so an incorrect value here makes every invite link go to the wrong host.
#   Local (this repo): http://localhost:3001
#   Local (Salty-Admin-Rahul-Repo clone): http://localhost:3000
#   Vercel: https://<your-deployment>.vercel.app  (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Resend — admin invites and the "email users" feature.
# Create a key at https://resend.com and verify a sending domain first.
# EMAIL_FROM's domain must match a domain you've verified in Resend.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Salty Support <support@support.saltydigital.ai>

# HMAC secret for signing marketing unsubscribe URLs. Any long random string works.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
UNSUBSCRIBE_TOKEN_SECRET=change-me
